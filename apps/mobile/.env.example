# URL de la API (cambiar en producción por la URL de Railway — disponible en dashboard tras primer deploy)
EXPO_PUBLIC_API_URL=http://localhost:3000

# AdMob — ID de unidad de anuncio de producción (obtener en AdMob Console)
# El ID de prueba de Google se usa automáticamente si esta variable no está definida
EXPO_PUBLIC_ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# Sentry (opcional en desarrollo — requerido en producción)
EXPO_PUBLIC_SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX
