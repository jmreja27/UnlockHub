# URL de la API (cambiar en producción por la URL de Railway — disponible en dashboard tras primer deploy)
EXPO_PUBLIC_API_URL=http://localhost:3000

# AdMob — IDs de unidades de anuncio de producción (obtener en AdMob Console)
# Los IDs de prueba de Google se usan automáticamente si estas variables no están definidas.
# Configurar como EAS secrets en expo.dev → proyecto → Secrets antes de cada build de producción.
EXPO_PUBLIC_ADMOB_HOME_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_SEARCH_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_RANKINGS_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_FRIENDS_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# Sentry (opcional en desarrollo — requerido en producción)
EXPO_PUBLIC_SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX
