# ─── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Base de datos (Neon PostgreSQL) ──────────────────────────────────────────
# DATABASE_URL → conexión pooled (para queries de la app en producción)
# DIRECT_URL   → conexión directa sin pooler (requerida por Prisma para migraciones)
#
# Obtener en: https://console.neon.tech → tu proyecto → Connection string
# Seleccionar "Pooled connection" para DATABASE_URL y "Direct connection" para DIRECT_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-xxx.eu-central-1.aws.neon.tech/unlockhub?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx-xxx.eu-central-1.aws.neon.tech/unlockhub?sslmode=require

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
# Obtener en: https://console.upstash.com → tu base de datos Redis → Details → REST URL
# O desde Fly.io: fly ext redis create → luego fly secrets list
REDIS_URL=rediss://default:PASSWORD@eu1-xxx-xxx.upstash.io:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=GENERAR_SECRETO_ALEATORIO_MIN_48_BYTES
JWT_REFRESH_SECRET=GENERAR_OTRO_SECRETO_DIFERENTE_MIN_48_BYTES
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# El origen de tu app móvil (puede ser * para apps móviles nativas o tu EAS Update URL)
CORS_ORIGIN=*

# ─── Cifrado AES-256 ──────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GENERAR_CLAVE_HEX_64_CARACTERES_32_BYTES

# ─── APIs externas ────────────────────────────────────────────────────────────
STEAM_API_KEY=TU_CLAVE_DE_STEAM_WEB_API

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Tier gratuito: 25GB almacenamiento, 25GB transferencia/mes
# Obtener en: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Tier gratuito: 5.000 errores/mes
# Obtener en: https://sentry.io → Settings → Projects → DSN
SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX

# ─── Mantenimiento ────────────────────────────────────────────────────────────
# Activar: fly secrets set MAINTENANCE_MODE="true"  → la app muestra pantalla de mantenimiento
# Desactivar: fly secrets set MAINTENANCE_MODE="false"
MAINTENANCE_MODE=false

# ─── Admin ────────────────────────────────────────────────────────────────────
# Protege el endpoint POST /api/v1/admin/maintenance/notify (envío de notificación push masiva)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=GENERAR_SECRETO_ALEATORIO

# ─── Cómo configurar en Fly.io ────────────────────────────────────────────────
# fly secrets set DATABASE_URL="postgresql://..." DIRECT_URL="postgresql://..." \
#   REDIS_URL="rediss://..." JWT_ACCESS_SECRET="..." JWT_REFRESH_SECRET="..." \
#   ENCRYPTION_KEY="..." STEAM_API_KEY="..." CLOUDINARY_URL="cloudinary://..." \
#   SENTRY_DSN="https://..."
