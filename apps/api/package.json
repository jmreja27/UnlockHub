{
  "name": "@unlockhub/api",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "mock": "node mock-server.js"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@sentry/node": "^10.51.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@unlockhub/types": "*",
    "@unlockhub/validators": "*",
    "axios": "^1.7.7",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.13.2",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "engine.io": "^6.6.9",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "file-type": "^22.0.1",
    "form-data": "^4.0.6",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.19.1",
    "psn-api": "^2.18.0",
    "resend": "^6.12.3",
    "socket.io": "^4.8.3",
    "socket.io-adapter": "^2.5.8",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.16.5",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.1"
  }
}
