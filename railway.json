{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "preDeployCommand": "cd apps/api && npx prisma migrate deploy",
    "startCommand": "${RAILPACK_START_COMMAND:-npm run start --workspace=apps/api}",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
